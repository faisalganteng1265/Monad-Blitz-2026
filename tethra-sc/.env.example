# Environment variables for Tethra Smart Contracts deployment and configuration
LOCAL_RPC_URL=http://127.0.0.1:8545
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=dummy

# Private key for deploying and managing contracts
PRIVATE_KEY=

# Wallet addresses (required)
DEPLOYER_ADDRESS=
RELAYER_WALLET=

# optional wallets (if different from DEPLOYER_ADDRESS)
TEAM_WALLET=
PROTOCOL_TREASURY=
KEEPER_WALLET=
PRICE_SIGNER_WALLET=

# Initial USDC amount for VaultPool (default 50,000 USDC with 6 decimals)
VAULTPOOL_INITIAL_USDC=50000000000